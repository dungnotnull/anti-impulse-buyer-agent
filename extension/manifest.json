{
  "manifest_version": 3,
  "name": "anti-impulse-buyer",
  "version": "0.1.0",
  "description": "Your wallet's guardian — freeze, analyze, and conquer impulse spending before it happens.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:7432/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dark_pattern_detector/detector.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "overlay/overlay.html",
        "overlay/overlay.css",
        "overlay/overlay.js",
        "onboarding/onboarding.html",
        "site_profiles.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/dist/index.html",
    "default_title": "anti-impulse-buyer"
  },
  "options_ui": {
    "page": "onboarding/onboarding.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
